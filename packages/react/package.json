{
  "name": "@examind/calculator-react",
  "version": "0.1.2",
  "description": "Headless React binding for the calculator: useCalculator() hook (reducer wiring, keyboard mapping, display selectors). Bring your own UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/examind-ai/calculator.git",
    "directory": "packages/react"
  },
  "keywords": [
    "calculator",
    "react",
    "hook",
    "headless"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "@examind/calculator-core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
